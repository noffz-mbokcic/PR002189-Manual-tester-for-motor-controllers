<?xml version="1.0" encoding="utf-8"?>
<UTPDataViewerSettings xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Version>15.0.0</Version>
  <General>
    <ConnectionAtStartup>Production</ConnectionAtStartup>
    <ShowBatchRunColumnsAndFilters>false</ShowBatchRunColumnsAndFilters>
    <ProcessCapabilityReport>
      <CpCapableLimit>1.67</CpCapableLimit>
      <CpLimitedCapableLimit>1.33</CpLimitedCapableLimit>
      <CpkCapableLimit>1.67</CpkCapableLimit>
      <CpkLimitedCapableLimit>1.33</CpkLimitedCapableLimit>
    </ProcessCapabilityReport>
    <MsaType1Report>
      <AssessBias>true</AssessBias>
      <CgToleranceFactor>0.2</CgToleranceFactor>
      <CgStandardDeviationFactor>6</CgStandardDeviationFactor>
      <CgkToleranceFactor>0.1</CgkToleranceFactor>
      <CgkStandardDeviationFactor>3</CgkStandardDeviationFactor>
    </MsaType1Report>
    <MsaType2And3Report>
      <AssessNdc>true</AssessNdc>
    </MsaType2And3Report>
    <MachineCapabilityReport>
      <CmCapableLimit>1.67</CmCapableLimit>
      <CmLimitedCapableLimit>1.33</CmLimitedCapableLimit>
      <CmkCapableLimit>1.67</CmkCapableLimit>
      <CmkLimitedCapableLimit>1.33</CmkLimitedCapableLimit>
    </MachineCapabilityReport>
  </General>
